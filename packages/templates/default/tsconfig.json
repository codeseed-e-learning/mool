{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist"
  },
  "include": [
    "app/**/*.ts",
    "bootstrap/**/*.ts",
    "config/**/*.ts",
    "database/**/*.ts",
    "routes/**/*.ts",
    "mool.config.ts"
  ]
}
